{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"],
            "@scripts/*": ["src/scripts/*"],
            "@error/*": ["src/scripts/error/*"],
            "@ui/*": ["src/ui/*"],
            "@components/*": ["src/ui/components/*"],
            "@styles/*": ["src/styles/*"]
        },    
    },
    "include": ["src"],
    "references": [
        { "path": "./tsconfig.app.json" },
        { "path": "./tsconfig.node.json" }
    ]
}